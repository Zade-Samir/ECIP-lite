# ECIP Lite — Example Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Ollama Server ────────────────────────────────────────────────────────────
# URL where your local Ollama instance is running
OLLAMA_BASE_URL=http://localhost:11434

# ─── LLM Model ────────────────────────────────────────────────────────────────
# The chat/completion model to use for answering queries
# Pull with: ollama pull qwen2.5-coder:3b
MODEL_NAME=qwen2.5-coder:3b

# ─── Embedding Model ──────────────────────────────────────────────────────────
# The embedding model for generating code vectors
# Pull with: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Dimension of the embedding vectors (must match the model)
# nomic-embed-text = 768
EMBEDDING_DIMENSION=768

# Number of chunks to embed in a single Ollama API call
EMBEDDING_BATCH_SIZE=8

# ─── LLM Generation Settings ──────────────────────────────────────────────────
TEMPERATURE=0.2
TOP_P=0.9
MAX_TOKENS=4096
STREAM=false

# ─── System Prompt ────────────────────────────────────────────────────────────
SYSTEM_PROMPT="You are ECIP, an expert Java and Spring Boot Architect. Answer questions about the codebase accurately and concisely, citing specific files and methods when relevant."

# ─── Storage Paths ────────────────────────────────────────────────────────────
# SQLite database path (auto-created on first run)
DATABASE_PATH=data/ecip.db

# FAISS index storage path (auto-created on first run)
FAISS_INDEX_PATH=.ecip/faiss.index
FAISS_METADATA_PATH=.ecip/faiss_meta.pkl

# ─── Caching ──────────────────────────────────────────────────────────────────
# Enable/disable the caching layer
CACHE_ENABLED=true

# Cache entry time-to-live in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE_PATH=logs/ecip.log

# ─── Profile ──────────────────────────────────────────────────────────────────
# Runtime profile: development, testing, production
ECIP_PROFILE=development
